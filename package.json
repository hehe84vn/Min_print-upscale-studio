{
  "name": "print-upscale-studio",
  "version": "0.1.0",
  "description": "Local desktop toolkit for AI upscaling, safe restoration, logo vectorization and print-text enhancement.",
  "main": "src/main/main.js",
  "author": "Min",
  "license": "MIT",
  "private": true,
  "scripts": {
    "start": "electron .",
    "lint": "node scripts/check-syntax.mjs",
    "test:smoke": "node scripts/smoke-test.mjs",
    "check": "npm run lint && npm run test:smoke",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win nsis portable --x64 --publish never",
    "dist:mac:x64": "electron-builder --mac dmg zip --x64 --publish never",
    "dist:mac:arm64": "electron-builder --mac dmg zip --arm64 --publish never"
  },
  "dependencies": {
    "@neplex/vectorizer": "0.1.0",
    "sharp": "0.35.3"
  },
  "devDependencies": {
    "electron": "43.1.1",
    "electron-builder": "26.15.3"
  },
  "build": {
    "appId": "vn.min.printupscalestudio",
    "productName": "Print Upscale Studio",
    "asar": true,
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "src/**/*",
      "package.json",
      "LICENSE",
      "THIRD_PARTY_NOTICES.md"
    ],
    "mac": {
      "category": "public.app-category.graphics-design",
      "target": ["dmg", "zip"],
      "artifactName": "${productName}-${version}-mac-${arch}.${ext}",
      "minimumSystemVersion": "12.0",
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "dmg": { "sign": false },
    "win": { "target": ["nsis", "portable"] },
    "nsis": {
      "artifactName": "${productName}-${version}-windows-${arch}-setup.${ext}",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Print Upscale Studio"
    },
    "portable": {
      "artifactName": "${productName}-${version}-windows-${arch}-portable.${ext}"
    },
    "asarUnpack": [
      "node_modules/@neplex/vectorizer*/**/*",
      "node_modules/@img/**/*",
      "node_modules/sharp/**/*"
    ]
  }
}
